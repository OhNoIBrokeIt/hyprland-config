{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "cssPriority": "user",
  "notification-icon-size": 48,
  "notification-body-image-height": 120,
  "notification-body-image-width": 200,
  "timeout": 6,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 180,
  "notification-window-width": 400,
  "control-center-width": 420,
  "control-center-height": 800,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰗩 Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "notifications": {
      "vexpand": true
    },
    "mpris": {
      "image-size": 72,
      "image-radius": 12
    },
    "volume": {
      "label": " "
    }
  }
}
